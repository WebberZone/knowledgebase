{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "knowledgebase/search",
  "version": "3.0.0",
  "title": "Knowledge Base Search",
  "category": "knowledgebase",
  "icon": "search",
  "keywords": [
    "knowledgebase",
    "search",
    "kb"
  ],
  "description": "Display a search form for the Knowledge Base",
  "supports": {
    "html": false,
    "align": true
  },
  "attributes": {
    "className": {
      "type": "string",
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "default": "Search the knowledgebase…"
    },
    "buttonText": {
      "type": "string",
      "default": "Search"
    }
  },
  "example": {},
  "textdomain": "knowledgebase",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css"
}